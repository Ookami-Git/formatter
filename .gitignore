# Dependency directories
node_modules/

# Local Git clone temp directory (used by the application)
git-repo/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Environments (contains secrets/tokens like GIT_TOKEN)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*

# IDEs and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS metadata
.DS_Store
Thumbs.db
ehthumbs.db

# Terraform / OpenTofu
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
