{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/exec", {"prepareCmd": "node scripts/prepare-release.cjs ${nextRelease.version}"}],
    ["@semantic-release/git", {"assets": ["package.json", "package-lock.json", "helm/Chart.yaml"], "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"}],
    "@semantic-release/github"
  ]
}
